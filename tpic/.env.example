# TPIC - Configuração de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais

# ============================================================================
# Claude API (OBRIGATÓRIO para análise visual inteligente)
# ============================================================================
# Obtenha sua chave em: https://console.anthropic.com
ANTHROPIC_API_KEY=seu_api_key_aqui

# ============================================================================
# Configuração do Navegador
# ============================================================================
# true para rodar em modo headless (sem janela), false para ver o navegador
HEADLESS=false

# ============================================================================
# Credenciais de Teste (OPCIONAIS - podem ser definidas em tempo de execução)
# ============================================================================
# Admin da Paróquia
ADMIN_PAROQUIA_USER=admin_paroquia
ADMIN_PAROQUIA_PASSWORD=senha123

# Email para teste de cadastro (será gerado automaticamente se não definido)
# TEST_EMAIL_DOMAIN=@test.com

# ============================================================================
# Configuração de Timeouts
# ============================================================================
# Tempo máximo de espera para elementos aparecerem (em ms)
# TIMEOUT=30000

# ============================================================================
# Logs e Relatórios
# ============================================================================
# Nível de logging: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
